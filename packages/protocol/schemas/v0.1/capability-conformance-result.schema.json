{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://seedspec.dev/schemas/v0.1/capability-conformance-result.schema.json",
  "title": "SeedSpec Capability Conformance Result 0.1 Alpha",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "protocol_version",
    "capability",
    "contract_digest",
    "suite_digest",
    "realization",
    "evaluator",
    "evaluated_at",
    "status",
    "checks"
  ],
  "properties": {
    "protocol_version": { "const": "0.1" },
    "capability": { "$ref": "#/$defs/capabilityIdentity" },
    "contract_digest": { "$ref": "#/$defs/digest" },
    "suite_digest": { "$ref": "#/$defs/digest" },
    "realization": { "$ref": "#/$defs/realization" },
    "evaluator": { "$ref": "#/$defs/evaluator" },
    "evaluated_at": { "type": "string", "format": "date-time" },
    "status": { "enum": ["not-run", "incomplete", "failed", "passed"] },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/checkResult" }
    }
  },
  "$defs": {
    "namespacedId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:\\.[a-z0-9][a-z0-9-]*){2,}$"
    },
    "localId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "semver": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
    },
    "capabilityVersion": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$"
    },
    "digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "capabilityIdentity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version"],
      "properties": {
        "id": { "$ref": "#/$defs/namespacedId" },
        "version": { "$ref": "#/$defs/capabilityVersion" }
      }
    },
    "realization": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reference"],
      "properties": {
        "reference": { "type": "string", "minLength": 1, "maxLength": 1000 },
        "digest": { "$ref": "#/$defs/digest" },
        "environment": { "type": "string", "minLength": 1, "maxLength": 500 }
      }
    },
    "evaluator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version"],
      "properties": {
        "id": { "$ref": "#/$defs/namespacedId" },
        "version": { "$ref": "#/$defs/semver" }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "reference"],
      "properties": {
        "source": { "enum": ["tool", "external-system", "implementing-agent", "end-user"] },
        "reference": { "type": "string", "minLength": 1, "maxLength": 1000 },
        "description": { "type": "string", "minLength": 1, "maxLength": 1000 }
      }
    },
    "checkResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "result", "evidence"],
      "properties": {
        "id": { "$ref": "#/$defs/localId" },
        "result": { "enum": ["not-run", "pass", "fail"] },
        "evidence": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/evidence" }
        },
        "note": { "type": "string", "minLength": 1, "maxLength": 1000 }
      },
      "allOf": [
        {
          "if": { "properties": { "result": { "const": "not-run" } }, "required": ["result"] },
          "then": { "properties": { "evidence": { "maxItems": 0 } } },
          "else": { "properties": { "evidence": { "minItems": 1 } } }
        }
      ]
    }
  }
}
