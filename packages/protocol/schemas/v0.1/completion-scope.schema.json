{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://seedspec.dev/schemas/v0.1/completion-scope.schema.json",
  "title": "Resolved SeedSpec Completion Scope 0.1 Alpha",
  "type": "object",
  "additionalProperties": false,
  "required": ["protocol_version", "status", "items", "uncovered_packages"],
  "properties": {
    "protocol_version": { "const": "0.1" },
    "status": { "enum": ["recorded", "review"] },
    "items": {
      "type": "array",
      "items": {
        "$ref": "https://seedspec.dev/schemas/v0.1/completion-scope-input.schema.json#/$defs/scopeItem"
      }
    },
    "uncovered_packages": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:\\.[a-z0-9][a-z0-9-]*){2,}$"
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "status": { "const": "recorded" } },
        "required": ["status"]
      },
      "then": {
        "properties": { "uncovered_packages": { "maxItems": 0 } }
      },
      "else": {
        "properties": { "uncovered_packages": { "minItems": 1 } }
      }
    }
  ]
}
