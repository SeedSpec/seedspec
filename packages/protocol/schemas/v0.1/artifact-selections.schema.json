{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://seedspec.dev/schemas/v0.1/artifact-selections.schema.json",
  "title": "SeedSpec Artifact Selections 0.1 Alpha",
  "type": "object",
  "additionalProperties": false,
  "required": ["protocol_version", "artifacts"],
  "properties": {
    "protocol_version": { "const": "0.1" },
    "artifacts": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/artifactSelection" }
    }
  },
  "$defs": {
    "namespacedId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:\\.[a-z0-9][a-z0-9-]*){2,}$"
    },
    "localId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "artifactSelection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["package", "id", "disposition"],
      "properties": {
        "package": { "$ref": "#/$defs/namespacedId" },
        "id": { "$ref": "#/$defs/localId" },
        "disposition": {
          "enum": ["selected", "declined", "deferred"]
        },
        "note": { "type": "string", "minLength": 1, "maxLength": 500 }
      }
    }
  }
}

