{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://seedspec.dev/schemas/v0.1/conformance.schema.json",
  "title": "SeedSpec Protocol Conformance Suite Index",
  "type": "object",
  "additionalProperties": false,
  "required": ["suite_version", "protocol_version", "cases"],
  "properties": {
    "suite_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "protocol_version": { "const": "0.1" },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/case" }
    }
  },
  "$defs": {
    "expectation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["result"],
      "properties": {
        "result": { "enum": ["pass", "fail"] },
        "code": { "type": "string", "minLength": 2 },
        "addition_order": {
          "type": "array",
          "items": { "type": "string", "minLength": 5 }
        },
        "project_status": { "enum": ["ready", "needs-input"] },
        "configuration_status": { "enum": ["selected", "review"] },
        "implementation_profile_status": { "enum": ["not-declared", "recorded", "review"] },
        "completion_scope_status": { "enum": ["recorded", "review"] },
        "review_count": { "type": "integer", "minimum": 0 },
        "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
        "preserved_extension": {
          "type": "object",
          "additionalProperties": false,
          "required": ["package", "key"],
          "properties": {
            "package": { "type": "string", "minLength": 5 },
            "key": { "type": "string", "minLength": 5 }
          }
        }
      },
      "allOf": [
        {
          "if": { "properties": { "result": { "const": "fail" } } },
          "then": { "required": ["code"] }
        }
      ]
    },
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "operation", "expect"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
        "description": { "type": "string", "minLength": 1 },
        "operation": { "enum": ["validate", "resolve", "digest-stability"] },
        "package": { "type": "string", "minLength": 1 },
        "root": { "type": "string", "minLength": 1 },
        "additions": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "decisions": { "type": "string", "minLength": 1 },
        "implementations": {
          "type": "array",
          "items": { "type": "string", "minLength": 2 }
        },
        "configuration_selection": { "enum": ["examples", "omitted"] },
        "expect": { "$ref": "#/$defs/expectation" }
      },
      "allOf": [
        {
          "if": { "properties": { "operation": { "enum": ["validate", "digest-stability"] } } },
          "then": { "required": ["package"] }
        },
        {
          "if": { "properties": { "operation": { "const": "resolve" } } },
          "then": { "required": ["root", "additions"] }
        }
      ]
    }
  }
}
