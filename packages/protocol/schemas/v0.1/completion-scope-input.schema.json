{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://seedspec.dev/schemas/v0.1/completion-scope-input.schema.json",
  "title": "SeedSpec Completion Scope Input 0.1 Alpha",
  "type": "object",
  "additionalProperties": false,
  "required": ["protocol_version", "items"],
  "properties": {
    "protocol_version": { "const": "0.1" },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/scopeItem" }
    }
  },
  "$defs": {
    "namespacedId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:\\.[a-z0-9][a-z0-9-]*){2,}$"
    },
    "localId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "references": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1, "maxLength": 80 }
    },
    "componentItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "id", "package", "component", "selection"],
      "properties": {
        "kind": { "const": "component" },
        "id": { "$ref": "#/$defs/localId" },
        "package": { "$ref": "#/$defs/namespacedId" },
        "component": { "const": "acceptance" },
        "selection": { "enum": ["all", "subset"] },
        "included_references": { "$ref": "#/$defs/references" },
        "deferred_references": { "$ref": "#/$defs/references" },
        "excluded_references": { "$ref": "#/$defs/references" },
        "note": { "type": "string", "minLength": 1, "maxLength": 500 }
      },
      "allOf": [
        {
          "if": {
            "properties": { "selection": { "const": "subset" } },
            "required": ["selection"]
          },
          "then": { "required": ["included_references"] },
          "else": {
            "not": {
              "anyOf": [
                { "required": ["included_references"] },
                { "required": ["deferred_references"] },
                { "required": ["excluded_references"] }
              ]
            }
          }
        }
      ]
    },
    "criterionItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "id", "package", "disposition", "statement"],
      "properties": {
        "kind": { "const": "criterion" },
        "id": { "$ref": "#/$defs/localId" },
        "package": { "$ref": "#/$defs/namespacedId" },
        "disposition": { "enum": ["included", "deferred", "excluded"] },
        "statement": { "type": "string", "minLength": 1, "maxLength": 1000 }
      }
    },
    "scopeItem": {
      "oneOf": [
        { "$ref": "#/$defs/componentItem" },
        { "$ref": "#/$defs/criterionItem" }
      ]
    }
  }
}
