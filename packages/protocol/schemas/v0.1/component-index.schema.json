{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://seedspec.dev/schemas/v0.1/component-index.schema.json",
  "title": "Resolved SeedSpec Component Index 0.1 Alpha",
  "type": "object",
  "additionalProperties": false,
  "required": ["protocol_version", "components"],
  "properties": {
    "protocol_version": { "const": "0.1" },
    "components": {
      "type": "array",
      "items": { "$ref": "#/$defs/resolvedComponent" }
    }
  },
  "$defs": {
    "namespacedId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:\\.[a-z0-9][a-z0-9-]*){2,}$"
    },
    "relativePath": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*(?:/[A-Za-z0-9][A-Za-z0-9._-]*)*/?$"
    },
    "review": {
      "enum": [
        "before-planning",
        "before-integration",
        "before-activation",
        "before-completion-claim",
        "when-relevant"
      ]
    },
    "resolvedComponent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["package", "name", "source_path", "path", "review"],
      "properties": {
        "package": { "$ref": "#/$defs/namespacedId" },
        "name": {
          "enum": [
            "acceptance",
            "integration",
            "evals",
            "examples",
            "reference",
            "deployment",
            "maintenance",
            "migration",
            "compatibility",
            "assets",
            "security",
            "generation_report"
          ]
        },
        "source_path": { "$ref": "#/$defs/relativePath" },
        "path": { "$ref": "#/$defs/relativePath" },
        "review": { "$ref": "#/$defs/review" }
      }
    }
  }
}
