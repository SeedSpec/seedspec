{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://seedspec.dev/schemas/v0.1/implementation-resource-state.schema.json",
  "title": "SeedSpec Implementation Resource Resolution State 0.1 Alpha",
  "type": "object",
  "additionalProperties": false,
  "required": ["protocol_version", "index_digest", "status", "resources"],
  "properties": {
    "protocol_version": { "const": "0.1" },
    "index_digest": { "$ref": "#/$defs/digest" },
    "status": { "enum": ["not-resolved", "resolved", "degraded", "failed"] },
    "resources": {
      "type": "array",
      "items": { "$ref": "#/$defs/resourceState" }
    }
  },
  "$defs": {
    "namespacedId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:\\.[a-z0-9][a-z0-9-]*){2,}$"
    },
    "semver": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
    },
    "digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "relativePath": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*(?:/[A-Za-z0-9][A-Za-z0-9._-]*)*/?$"
    },
    "resourceState": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "package",
        "id",
        "kind",
        "usage",
        "entrypoint",
        "resolution_status",
        "use_status"
      ],
      "properties": {
        "package": { "$ref": "#/$defs/namespacedId" },
        "id": { "$ref": "#/$defs/namespacedId" },
        "kind": {
          "enum": ["skill", "instructions", "verification", "tool", "target-profile"]
        },
        "usage": { "enum": ["expected", "recommended", "available"] },
        "entrypoint": { "$ref": "#/$defs/relativePath" },
        "resolution_status": {
          "enum": ["not-resolved", "online", "bundled", "bundled-fallback", "unavailable"]
        },
        "resolved_version": { "$ref": "#/$defs/semver" },
        "digest": { "$ref": "#/$defs/digest" },
        "path": { "$ref": "#/$defs/relativePath" },
        "source_url": { "type": "string", "format": "uri" },
        "reason_code": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]*$" },
        "reason": { "type": "string", "minLength": 1, "maxLength": 1000 },
        "use_status": { "enum": ["not-recorded", "consulted", "skipped"] },
        "use_reason": { "type": "string", "minLength": 1, "maxLength": 1000 }
      }
    }
  }
}
