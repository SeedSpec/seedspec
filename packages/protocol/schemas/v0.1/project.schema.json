{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://seedspec.dev/schemas/v0.1/project.schema.json",
  "title": "Resolved SeedSpec Project 0.1 Alpha",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "protocol_version",
    "status",
    "configuration_status",
    "completion_scope_status",
    "declaration_status",
    "artifact_status",
    "implementation_profile_status",
    "root",
    "additions",
    "configuration",
    "component_index",
    "artifact_index",
    "implementation_resource_index",
    "implementation_resource_state",
    "implementation_profile_state",
    "lockfile",
    "resolved_spec",
    "agent_guide",
    "implementation_notes",
    "verification_report",
    "completion_scope",
    "verification_state",
    "resolved_decisions",
    "unresolved_decisions"
  ],
  "properties": {
    "protocol_version": { "const": "0.1" },
    "status": { "enum": ["ready", "needs-input"] },
    "configuration_status": { "enum": ["selected", "review"] },
    "completion_scope_status": { "enum": ["recorded", "review"] },
    "declaration_status": { "enum": ["no-declared-concerns", "review"] },
    "artifact_status": { "enum": ["recorded", "review"] },
    "implementation_profile_status": { "enum": ["not-declared", "recorded", "review"] },
    "root": { "$ref": "#/$defs/packageRef" },
    "additions": {
      "type": "array",
      "items": { "$ref": "#/$defs/packageRef" }
    },
    "configuration": { "const": "resolved-config.yaml" },
    "component_index": { "const": "components.yaml" },
    "artifact_index": { "const": "artifacts.yaml" },
    "implementation_resource_index": { "const": "implementation-resources.yaml" },
    "implementation_resource_state": { "const": "implementation-resource-state.yaml" },
    "implementation_profile_state": { "const": "implementation-profile-state.yaml" },
    "lockfile": { "const": "dependencies.lock.yaml" },
    "resolved_spec": { "const": "resolved-spec.md" },
    "agent_guide": { "const": "agent-guide.md" },
    "implementation_notes": { "const": "implementation-notes.md" },
    "verification_report": { "const": "verification-report.md" },
    "completion_scope": { "const": "completion-scope.yaml" },
    "verification_state": { "const": "verification-state.yaml" },
    "resolved_decisions": {
      "type": "array",
      "items": { "$ref": "#/$defs/resolvedDecision" }
    },
    "unresolved_decisions": {
      "type": "array",
      "items": { "$ref": "#/$defs/unresolvedDecision" }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "status": { "const": "ready" } },
        "required": ["status"]
      },
      "then": {
        "properties": {
          "configuration_status": { "const": "selected" },
          "implementation_profile_status": { "enum": ["not-declared", "recorded"] },
          "unresolved_decisions": {
            "items": {
              "allOf": [
                { "$ref": "#/$defs/unresolvedDecision" },
                {
                  "properties": { "required": { "const": false } },
                  "required": ["required"]
                }
              ]
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": { "status": { "const": "needs-input" } },
        "required": ["status"]
      },
      "then": {
        "anyOf": [
          {
            "properties": {
              "configuration_status": { "const": "review" }
            }
          },
          {
            "properties": {
              "unresolved_decisions": {
                "contains": {
                  "properties": { "required": { "const": true } },
                  "required": ["required"]
                }
              }
            }
          },
          {
            "properties": {
              "implementation_profile_status": { "const": "review" }
            }
          }
        ]
      }
    }
  ],
  "$defs": {
    "digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "packageRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "digest"],
      "properties": {
        "id": { "$ref": "#/$defs/namespacedId" },
        "version": { "$ref": "#/$defs/semver" },
        "digest": { "$ref": "#/$defs/digest" }
      }
    },
    "resolvedDecision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["package", "id", "answer"],
      "properties": {
        "package": { "$ref": "#/$defs/namespacedId" },
        "id": { "$ref": "#/$defs/localId" },
        "answer": { "type": "string", "minLength": 1 }
      }
    },
    "unresolvedDecision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["package", "id", "question", "required"],
      "properties": {
        "package": { "$ref": "#/$defs/namespacedId" },
        "id": { "$ref": "#/$defs/localId" },
        "question": { "type": "string", "minLength": 1 },
        "required": { "type": "boolean" },
        "options": {
          "type": "array",
          "minItems": 2,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "namespacedId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:\\.[a-z0-9][a-z0-9-]*){2,}$"
    },
    "localId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "semver": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
    }
  }
}
