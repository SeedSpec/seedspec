{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://seedspec.dev/schemas/v0.1/verification-state.schema.json",
  "title": "SeedSpec Verification State 0.1 Alpha",
  "type": "object",
  "additionalProperties": false,
  "required": ["protocol_version", "scope_digest", "status", "items"],
  "properties": {
    "protocol_version": { "const": "0.1" },
    "scope_digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "status": {
      "enum": ["not-started", "in-progress", "failed", "verified-with-gaps", "verified"]
    },
    "items": {
      "type": "array",
      "items": { "$ref": "#/$defs/verificationItem" }
    }
  },
  "$defs": {
    "localId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "verificationItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "result", "evidence"],
      "properties": {
        "id": { "$ref": "#/$defs/localId" },
        "result": { "enum": ["not-run", "pass", "partial", "fail"] },
        "evidence": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1, "maxLength": 500 }
        },
        "note": { "type": "string", "minLength": 1, "maxLength": 1000 }
      },
      "allOf": [
        {
          "if": {
            "properties": { "result": { "const": "not-run" } },
            "required": ["result"]
          },
          "then": { "properties": { "evidence": { "maxItems": 0 } } },
          "else": { "properties": { "evidence": { "minItems": 1 } } }
        }
      ]
    }
  }
}
