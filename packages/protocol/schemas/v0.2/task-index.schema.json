{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://seedspec.dev/releases/0.2.0/schemas/task-index.schema.json",
  "title": "Resolved SeedSpec Task Index 0.1 Alpha",
  "type": "object",
  "additionalProperties": false,
  "required": ["protocol_version", "packages"],
  "properties": {
    "protocol_version": { "const": "0.2" },
    "packages": {
      "type": "array",
      "items": { "$ref": "#/$defs/packageTasks" }
    }
  },
  "$defs": {
    "namespacedId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:\\.[a-z0-9][a-z0-9-]*){2,}$"
    },
    "localId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "relativeFilePath": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*(?:/[A-Za-z0-9][A-Za-z0-9._-]*)*$"
    },
    "resolvedReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_path", "path"],
      "properties": {
        "source_path": { "$ref": "#/$defs/relativeFilePath" },
        "path": { "$ref": "#/$defs/relativeFilePath" }
      }
    },
    "resolvedTask": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "instruction", "references"],
      "properties": {
        "id": { "$ref": "#/$defs/localId" },
        "instruction": { "type": "string", "minLength": 1, "maxLength": 4000 },
        "references": {
          "type": "array",
          "items": { "$ref": "#/$defs/resolvedReference" }
        }
      }
    },
    "packageTasks": {
      "type": "object",
      "additionalProperties": false,
      "required": ["package", "source_path", "tasks"],
      "properties": {
        "package": { "$ref": "#/$defs/namespacedId" },
        "source_path": { "$ref": "#/$defs/relativeFilePath" },
        "tasks": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/resolvedTask" }
        }
      }
    }
  }
}
