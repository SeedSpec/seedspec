{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://seedspec.dev/releases/0.2.0/schemas/seedspec.schema.json",
  "title": "SeedSpec package Manifest 0.1 Alpha",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "protocol_version",
    "id",
    "name",
    "version",
    "kind",
    "definition",
    "configuration",
    "provides"
  ],
  "properties": {
    "protocol_version": { "const": "0.2" },
    "id": { "$ref": "#/$defs/namespacedId" },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100
    },
    "version": { "$ref": "#/$defs/semver" },
    "kind": {
      "description": "An author-supplied hint about the expected shape of the outcome. It guides tools and agents but does not determine composition position or impose kind-specific validity rules.",
      "oneOf": [
        {
          "enum": [
            "solution",
            "application",
            "feature",
            "workflow",
            "automation",
            "configuration",
            "integration"
          ]
        },
        { "$ref": "#/$defs/namespacedId" }
      ]
    },
    "description": {
      "type": "string",
      "maxLength": 500
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "license": { "type": "string", "minLength": 1, "maxLength": 100 },
        "homepage": { "type": "string", "format": "uri" },
        "repository": { "type": "string", "format": "uri" },
        "documentation": { "type": "string", "format": "uri" }
      }
    },
    "definition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entrypoint"],
      "properties": {
        "entrypoint": { "$ref": "#/$defs/relativePath" },
        "artifact": {
          "description": "Optional artifact ID identifying the native format of the primary intent entrypoint. The referenced artifact must use the same local path and declare the intent concern.",
          "$ref": "#/$defs/localId"
        }
      }
    },
    "configuration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema", "example"],
      "properties": {
        "schema": { "$ref": "#/$defs/relativePath" },
        "example": { "$ref": "#/$defs/relativePath" },
        "guide": { "$ref": "#/$defs/relativePath" }
      }
    },
    "requires": { "$ref": "#/$defs/requirementDeclaration" },
    "provides": { "$ref": "#/$defs/provisionDeclaration" },
    "conflicts": { "$ref": "#/$defs/conflictDeclaration" },
    "decisions": {
      "type": "array",
      "items": { "$ref": "#/$defs/decision" }
    },
    "implementation_profiles": {
      "type": "array",
      "items": { "$ref": "#/$defs/implementationProfile" }
    },
    "components": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "acceptance": { "$ref": "#/$defs/relativePath" },
        "integration": { "$ref": "#/$defs/relativePath" },
        "evals": { "$ref": "#/$defs/relativePath" },
        "examples": { "$ref": "#/$defs/relativePath" },
        "reference": { "$ref": "#/$defs/relativePath" },
        "deployment": { "$ref": "#/$defs/relativePath" },
        "maintenance": { "$ref": "#/$defs/relativePath" },
        "migration": { "$ref": "#/$defs/relativePath" },
        "compatibility": { "$ref": "#/$defs/relativePath" },
        "assets": { "$ref": "#/$defs/relativePath" },
        "security": { "$ref": "#/$defs/relativePath" },
        "generation_report": { "$ref": "#/$defs/relativePath" }
      }
    },
    "artifacts": {
      "type": "array",
      "items": { "$ref": "#/$defs/artifact" }
    },
    "relationships": {
      "type": "array",
      "items": { "$ref": "#/$defs/artifactRelationship" }
    },
    "implementation_resources": {
      "$ref": "#/$defs/implementationResourceDeclaration"
    },
    "tasks": {
      "description": "Package-relative path to an ordered implementation task runbook.",
      "$ref": "#/$defs/relativePath"
    },
    "compatibility": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["scope"],
          "properties": { "scope": { "const": "generic" } }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["scope", "domain"],
          "properties": {
            "scope": { "const": "domain" },
            "domain": { "$ref": "#/$defs/namespacedId" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["scope", "applications"],
          "properties": {
            "scope": { "const": "application" },
            "applications": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": { "$ref": "#/$defs/namespacedId" }
            }
          }
        }
      ]
    },
    "extensions": {
      "type": "object",
      "propertyNames": { "$ref": "#/$defs/namespacedId" },
      "additionalProperties": true
    }
  },
  "$defs": {
    "namespacedId": {
      "type": "string",
      "minLength": 5,
      "maxLength": 160,
      "pattern": "^[a-z0-9]+(?:\\.[a-z0-9][a-z0-9-]*){2,}$"
    },
    "localId": {
      "type": "string",
      "minLength": 2,
      "maxLength": 80,
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*(?:/[A-Za-z0-9][A-Za-z0-9._-]*)*/?$"
    },
    "semver": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
    },
    "digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "capabilityVersion": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$"
    },
    "capabilityRequirement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "tested_against"],
      "properties": {
        "id": { "$ref": "#/$defs/namespacedId" },
        "tested_against": { "$ref": "#/$defs/capabilityVersion" }
      }
    },
    "capabilityProvision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "contract"],
      "properties": {
        "id": { "$ref": "#/$defs/namespacedId" },
        "version": { "$ref": "#/$defs/capabilityVersion" },
        "contract": { "$ref": "#/$defs/relativePath" },
        "change_history": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/capabilityRevisionChange" }
        },
        "conformance": { "$ref": "#/$defs/capabilityConformance" }
      }
    },
    "capabilityChange": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "summary"],
      "properties": {
        "id": { "$ref": "#/$defs/localId" },
        "type": { "enum": ["breaking", "additive", "clarifying"] },
        "summary": { "type": "string", "minLength": 1, "maxLength": 500 },
        "contract_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/localId" }
        }
      }
    },
    "capabilityRevisionChange": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "to", "changes"],
      "properties": {
        "from": { "$ref": "#/$defs/capabilityVersion" },
        "to": { "$ref": "#/$defs/capabilityVersion" },
        "changes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/capabilityChange" }
        }
      }
    },
    "capabilityConformance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["suite"],
      "properties": {
        "suite": { "$ref": "#/$defs/relativePath" }
      }
    },
    "requirementDeclaration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["capabilities"],
      "properties": {
        "capabilities": {
          "type": "array",
          "items": { "$ref": "#/$defs/capabilityRequirement" }
        }
      }
    },
    "provisionDeclaration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["capabilities"],
      "properties": {
        "capabilities": {
          "type": "array",
          "items": { "$ref": "#/$defs/capabilityProvision" }
        }
      }
    },
    "conflictItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "reason"],
      "properties": {
        "id": { "$ref": "#/$defs/namespacedId" },
        "reason": { "type": "string", "minLength": 1, "maxLength": 500 }
      }
    },
    "conflictDeclaration": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "packages": {
          "type": "array",
          "items": { "$ref": "#/$defs/conflictItem" }
        },
        "capabilities": {
          "type": "array",
          "items": { "$ref": "#/$defs/conflictItem" }
        }
      }
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "question", "required"],
      "properties": {
        "id": { "$ref": "#/$defs/localId" },
        "question": { "type": "string", "minLength": 1, "maxLength": 500 },
        "required": { "type": "boolean" },
        "options": {
          "type": "array",
          "minItems": 2,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1, "maxLength": 100 }
        }
      }
    },
    "implementationCondition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "statement", "verification"],
      "properties": {
        "id": { "$ref": "#/$defs/localId" },
        "statement": { "type": "string", "minLength": 1, "maxLength": 500 },
        "verification": { "$ref": "#/$defs/conditionVerification" }
      }
    },
    "conditionVerification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["method", "evidence"],
      "properties": {
        "method": {
          "oneOf": [
            {
              "enum": [
                "user-confirmation",
                "environment-inspection",
                "tool-check",
                "document-review",
                "manual-observation"
              ]
            },
            { "$ref": "#/$defs/namespacedId" }
          ]
        },
        "evidence": { "enum": ["none", "optional", "required"] },
        "guidance": { "type": "string", "minLength": 1, "maxLength": 500 }
      }
    },
    "implementationProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "description"],
      "properties": {
        "id": { "$ref": "#/$defs/localId" },
        "name": { "type": "string", "minLength": 1, "maxLength": 100 },
        "description": { "type": "string", "minLength": 1, "maxLength": 500 },
        "guidance": { "$ref": "#/$defs/relativePath" },
        "prerequisites": {
          "type": "array",
          "items": { "$ref": "#/$defs/implementationCondition" }
        },
        "blockers": {
          "type": "array",
          "items": { "$ref": "#/$defs/implementationCondition" }
        },
        "tradeoffs": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1, "maxLength": 500 }
        },
        "implementation_resources": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/namespacedId" }
        }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type"],
      "properties": {
        "id": { "$ref": "#/$defs/localId" },
        "type": { "$ref": "#/$defs/namespacedId" },
        "path": { "$ref": "#/$defs/relativePath" },
        "url": { "type": "string", "format": "uri" },
        "label": { "type": "string", "minLength": 1, "maxLength": 160 },
        "description": { "type": "string", "minLength": 1, "maxLength": 500 },
        "media_type": { "type": "string", "minLength": 1, "maxLength": 160 },
        "format_version": { "type": "string", "minLength": 1, "maxLength": 100 },
        "conforms_to": { "type": "string", "format": "uri" },
        "concerns": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/namespacedId" }
        },
        "evidence_for": {
          "description": "Package-scoped claims for which this artifact is offered as evidence. Package evidence does not prove a later realization.",
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["subject", "claim"],
            "properties": {
              "subject": { "const": "package" },
              "claim": { "type": "string", "minLength": 1, "maxLength": 500 }
            }
          }
        }
      },
      "oneOf": [
        { "required": ["path"], "not": { "required": ["url"] } },
        { "required": ["url"], "not": { "required": ["path"] } }
      ]
    },
    "artifactRelationship": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "type", "to"],
      "properties": {
        "from": { "$ref": "#/$defs/localId" },
        "type": { "$ref": "#/$defs/namespacedId" },
        "to": { "$ref": "#/$defs/localId" },
        "description": { "type": "string", "minLength": 1, "maxLength": 500 }
      }
    },
    "guidanceCatalog": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "url", "version"],
      "properties": {
        "id": { "$ref": "#/$defs/namespacedId" },
        "url": { "type": "string", "format": "uri" },
        "version": { "$ref": "#/$defs/semver" },
        "digest": { "$ref": "#/$defs/digest" }
      }
    },
    "resourceApplicability": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "capabilities": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/namespacedId" }
        },
        "targets": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/namespacedId" }
        }
      },
      "anyOf": [
        { "required": ["capabilities"] },
        { "required": ["targets"] }
      ]
    },
    "canonicalResource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["manifest_url"],
      "properties": {
        "manifest_url": { "type": "string", "format": "uri" },
        "digest": { "$ref": "#/$defs/digest" }
      }
    },
    "bundledResource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "version", "digest", "compatibility"],
      "properties": {
        "path": { "$ref": "#/$defs/relativePath" },
        "version": { "$ref": "#/$defs/semver" },
        "digest": { "$ref": "#/$defs/digest" },
        "compatibility": { "enum": ["exact", "author-declared-compatible"] }
      }
    },
    "implementationResource": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "description",
        "usage",
        "entrypoint",
        "version",
        "update_policy"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/namespacedId" },
        "kind": {
          "enum": ["skill", "instructions", "verification", "tool", "target-profile"]
        },
        "description": { "type": "string", "minLength": 1, "maxLength": 500 },
        "usage": { "enum": ["expected", "recommended", "available"] },
        "entrypoint": { "$ref": "#/$defs/relativePath" },
        "version": { "$ref": "#/$defs/semver" },
        "update_policy": { "enum": ["exact", "latest-compatible", "latest"] },
        "canonical": { "$ref": "#/$defs/canonicalResource" },
        "bundled": { "$ref": "#/$defs/bundledResource" },
        "applies_to": { "$ref": "#/$defs/resourceApplicability" }
      },
      "anyOf": [
        { "required": ["canonical"] },
        { "required": ["bundled"] }
      ],
      "allOf": [
        {
          "if": {
            "properties": { "update_policy": { "const": "exact" } },
            "required": ["update_policy", "canonical"]
          },
          "then": {
            "properties": {
              "canonical": { "required": ["digest"] }
            }
          }
        }
      ]
    },
    "implementationResourceDeclaration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["additional_guidance", "resources"],
      "properties": {
        "additional_guidance": { "enum": ["none", "agent-delegated"] },
        "catalogs": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/guidanceCatalog" }
        },
        "resources": {
          "type": "array",
          "items": { "$ref": "#/$defs/implementationResource" }
        }
      }
    }
  }
}
