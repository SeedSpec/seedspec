{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://seedspec.dev/releases/0.2.0/schemas/task-runbook.schema.json",
  "title": "SeedSpec Package Task Runbook 0.1 Alpha",
  "type": "object",
  "additionalProperties": false,
  "required": ["protocol_version", "tasks"],
  "properties": {
    "protocol_version": { "const": "0.2" },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/task" }
    }
  },
  "$defs": {
    "localId": {
      "type": "string",
      "minLength": 2,
      "maxLength": 80,
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "relativeFilePath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*(?:/[A-Za-z0-9][A-Za-z0-9._-]*)*$"
    },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "instruction"],
      "properties": {
        "id": { "$ref": "#/$defs/localId" },
        "instruction": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4000
        },
        "references": {
          "type": "array",
          "minItems": 1,
          "maxItems": 50,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/relativeFilePath" }
        }
      }
    }
  }
}
