{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://seedspec.dev/releases/0.2.0/schemas/implementation-resource-manifest.schema.json",
  "title": "Published SeedSpec Implementation Resource Manifest 0.1 Alpha",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "protocol_version",
    "id",
    "version",
    "kind",
    "description",
    "entrypoint",
    "digest",
    "files"
  ],
  "properties": {
    "protocol_version": { "const": "0.2" },
    "id": { "$ref": "#/$defs/namespacedId" },
    "version": { "$ref": "#/$defs/semver" },
    "kind": {
      "enum": ["skill", "instructions", "verification", "tool", "target-profile"]
    },
    "description": { "type": "string", "minLength": 1, "maxLength": 500 },
    "entrypoint": { "$ref": "#/$defs/relativePath" },
    "digest": { "$ref": "#/$defs/digest" },
    "files": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100,
      "items": { "$ref": "#/$defs/resourceFile" }
    }
  },
  "$defs": {
    "namespacedId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:\\.[a-z0-9][a-z0-9-]*){2,}$"
    },
    "semver": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
    },
    "digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*(?:/[A-Za-z0-9][A-Za-z0-9._-]*)*$"
    },
    "resourceFile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "url", "digest"],
      "properties": {
        "path": { "$ref": "#/$defs/relativePath" },
        "url": { "type": "string", "format": "uri" },
        "digest": { "$ref": "#/$defs/digest" },
        "media_type": { "type": "string", "minLength": 1, "maxLength": 160 }
      }
    }
  }
}
