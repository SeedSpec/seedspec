{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://seedspec.dev/releases/0.2.0/schemas/implementation-resource-index.schema.json",
  "title": "Resolved SeedSpec Implementation Resource Index 0.1 Alpha",
  "type": "object",
  "additionalProperties": false,
  "required": ["protocol_version", "policies", "resources"],
  "properties": {
    "protocol_version": { "const": "0.2" },
    "policies": {
      "type": "array",
      "items": { "$ref": "#/$defs/packagePolicy" }
    },
    "resources": {
      "type": "array",
      "items": { "$ref": "#/$defs/resolvedResource" }
    }
  },
  "$defs": {
    "namespacedId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:\\.[a-z0-9][a-z0-9-]*){2,}$"
    },
    "semver": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
    },
    "digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "relativePath": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*(?:/[A-Za-z0-9][A-Za-z0-9._-]*)*/?$"
    },
    "catalog": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "url", "version"],
      "properties": {
        "id": { "$ref": "#/$defs/namespacedId" },
        "url": { "type": "string", "format": "uri" },
        "version": { "$ref": "#/$defs/semver" },
        "digest": { "$ref": "#/$defs/digest" }
      }
    },
    "packagePolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["package", "additional_guidance", "catalogs"],
      "properties": {
        "package": { "$ref": "#/$defs/namespacedId" },
        "additional_guidance": { "enum": ["unspecified", "none", "agent-delegated"] },
        "catalogs": {
          "type": "array",
          "items": { "$ref": "#/$defs/catalog" }
        }
      }
    },
    "applicability": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "capabilities": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/namespacedId" }
        },
        "targets": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/namespacedId" }
        }
      }
    },
    "canonical": {
      "type": "object",
      "additionalProperties": false,
      "required": ["manifest_url"],
      "properties": {
        "manifest_url": { "type": "string", "format": "uri" },
        "digest": { "$ref": "#/$defs/digest" }
      }
    },
    "bundled": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "source_path", "version", "digest", "compatibility"],
      "properties": {
        "path": { "$ref": "#/$defs/relativePath" },
        "source_path": { "$ref": "#/$defs/relativePath" },
        "version": { "$ref": "#/$defs/semver" },
        "digest": { "$ref": "#/$defs/digest" },
        "compatibility": { "enum": ["exact", "author-declared-compatible"] }
      }
    },
    "resolvedResource": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "package",
        "id",
        "kind",
        "description",
        "usage",
        "entrypoint",
        "version",
        "update_policy"
      ],
      "properties": {
        "package": { "$ref": "#/$defs/namespacedId" },
        "id": { "$ref": "#/$defs/namespacedId" },
        "kind": {
          "enum": ["skill", "instructions", "verification", "tool", "target-profile"]
        },
        "description": { "type": "string", "minLength": 1 },
        "usage": { "enum": ["expected", "recommended", "available"] },
        "entrypoint": { "$ref": "#/$defs/relativePath" },
        "version": { "$ref": "#/$defs/semver" },
        "update_policy": { "enum": ["exact", "latest-compatible", "latest"] },
        "canonical": { "$ref": "#/$defs/canonical" },
        "bundled": { "$ref": "#/$defs/bundled" },
        "applies_to": { "$ref": "#/$defs/applicability" }
      },
      "anyOf": [
        { "required": ["canonical"] },
        { "required": ["bundled"] }
      ]
    }
  }
}
