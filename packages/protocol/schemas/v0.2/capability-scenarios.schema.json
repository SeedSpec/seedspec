{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://seedspec.dev/releases/0.2.0/schemas/capability-scenarios.schema.json",
  "title": "SeedSpec Capability Acceptance Scenarios 0.1 Alpha",
  "type": "object",
  "additionalProperties": false,
  "required": ["protocol_version", "capability", "scenarios"],
  "properties": {
    "protocol_version": { "const": "0.2" },
    "capability": { "$ref": "#/$defs/capabilityIdentity" },
    "scenarios": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/scenario" }
    }
  },
  "$defs": {
    "namespacedId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:\\.[a-z0-9][a-z0-9-]*){2,}$"
    },
    "localId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "capabilityVersion": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$"
    },
    "capabilityIdentity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version"],
      "properties": {
        "id": { "$ref": "#/$defs/namespacedId" },
        "version": { "$ref": "#/$defs/capabilityVersion" }
      }
    },
    "scenario": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "description", "operation", "expect"],
      "properties": {
        "id": { "$ref": "#/$defs/localId" },
        "description": { "type": "string", "minLength": 1, "maxLength": 500 },
        "operation": { "$ref": "#/$defs/localId" },
        "given": { "type": "object" },
        "input": { "type": "object" },
        "expect": { "type": "object", "minProperties": 1 }
      }
    }
  }
}
