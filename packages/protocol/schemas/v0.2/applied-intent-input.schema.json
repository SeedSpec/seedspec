{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://seedspec.dev/releases/0.2.0/schemas/applied-intent-input.schema.json",
  "title": "SeedSpec Applied Intent Input 0.1 Alpha",
  "type": "object",
  "additionalProperties": false,
  "required": ["protocol_version", "packages", "contributions"],
  "properties": {
    "protocol_version": { "const": "0.2" },
    "packages": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/packageUse" }
    },
    "contributions": {
      "type": "array",
      "items": { "$ref": "#/$defs/contribution" }
    }
  },
  "$defs": {
    "namespacedId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:\\.[a-z0-9][a-z0-9-]*){2,}$"
    },
    "localId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "packageUse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["package", "use"],
      "properties": {
        "package": { "$ref": "#/$defs/namespacedId" },
        "use": { "enum": ["as-authored", "adapted", "partial"] },
        "note": { "type": "string", "minLength": 1, "maxLength": 1000 }
      },
      "allOf": [
        {
          "if": {
            "properties": { "use": { "enum": ["adapted", "partial"] } },
            "required": ["use"]
          },
          "then": { "required": ["note"] }
        }
      ]
    },
    "verificationPlan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["subject", "method", "timing", "evidence"],
      "properties": {
        "subject": { "enum": ["baseline", "realization", "outcome"] },
        "method": {
          "oneOf": [
            {
              "enum": [
                "user-confirmation",
                "environment-inspection",
                "tool-check",
                "document-review",
                "manual-observation"
              ]
            },
            { "$ref": "#/$defs/namespacedId" }
          ]
        },
        "timing": {
          "enum": [
            "before-implementation",
            "during-realization",
            "completion",
            "post-realization"
          ]
        },
        "evidence": { "enum": ["optional", "required"] },
        "guidance": { "type": "string", "minLength": 1, "maxLength": 1000 }
      }
    },
    "baselineEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["subject", "reference", "source"],
      "properties": {
        "subject": { "const": "baseline" },
        "reference": { "type": "string", "minLength": 1, "maxLength": 2000 },
        "source": { "enum": ["end-user", "agent", "tool", "external-system"] },
        "description": { "type": "string", "minLength": 1, "maxLength": 1000 },
        "observed_at": { "type": "string", "format": "date-time" }
      }
    },
    "contribution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "category", "statement", "source", "status"],
      "properties": {
        "id": { "$ref": "#/$defs/localId" },
        "category": {
          "enum": [
            "objective",
            "outcome",
            "invariant",
            "constraint",
            "forbidden-state",
            "non-goal",
            "preference",
            "decision-right",
            "baseline-observation"
          ]
        },
        "statement": { "type": "string", "minLength": 1, "maxLength": 2000 },
        "source": { "enum": ["end-user", "agent"] },
        "status": { "enum": ["affirmed", "proposed", "observed"] },
        "verification": { "$ref": "#/$defs/verificationPlan" },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/baselineEvidence" }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "source": { "const": "end-user" } },
            "required": ["source"]
          },
          "then": {
            "properties": { "status": { "enum": ["affirmed", "observed"] } }
          }
        },
        {
          "if": {
            "properties": { "status": { "const": "proposed" } },
            "required": ["status"]
          },
          "then": {
            "properties": { "source": { "const": "agent" } }
          }
        },
        {
          "if": {
            "properties": { "category": { "const": "baseline-observation" } },
            "required": ["category"]
          },
          "then": {
            "properties": {
              "status": { "const": "observed" },
              "verification": {
                "allOf": [
                  { "$ref": "#/$defs/verificationPlan" },
                  { "properties": { "subject": { "const": "baseline" } } }
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": { "status": { "const": "observed" } },
            "required": ["status"]
          },
          "then": {
            "required": ["evidence"],
            "properties": { "category": { "const": "baseline-observation" } }
          }
        },
        {
          "if": { "required": ["evidence"] },
          "then": {
            "properties": {
              "category": { "const": "baseline-observation" },
              "status": { "const": "observed" }
            }
          }
        }
      ]
    }
  }
}
