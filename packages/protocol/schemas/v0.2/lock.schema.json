{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://seedspec.dev/releases/0.2.0/schemas/lock.schema.json",
  "title": "SeedSpec Dependency Lock 0.1 Alpha",
  "type": "object",
  "additionalProperties": false,
  "required": ["protocol_version", "resolution_algorithm", "root", "additions", "capabilities", "requirements", "reviews"],
  "properties": {
    "protocol_version": { "const": "0.2" },
    "resolution_algorithm": { "const": "declaration-review-v1" },
    "root": { "$ref": "#/$defs/lockedPackage" },
    "additions": {
      "type": "array",
      "items": { "$ref": "#/$defs/lockedPackage" }
    },
    "capabilities": {
      "type": "array",
      "items": { "$ref": "#/$defs/resolvedCapability" }
    },
    "requirements": {
      "type": "array",
      "items": { "$ref": "#/$defs/requirementBinding" }
    },
    "reviews": {
      "type": "array",
      "items": { "$ref": "#/$defs/compositionReview" }
    }
  },
  "$defs": {
    "digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "lockedPackage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "kind", "digest"],
      "properties": {
        "id": { "$ref": "#/$defs/namespacedId" },
        "version": { "$ref": "#/$defs/semver" },
        "kind": {
          "oneOf": [
            { "enum": ["solution", "application", "feature", "workflow", "automation", "configuration", "integration"] },
            { "$ref": "#/$defs/namespacedId" }
          ]
        },
        "digest": { "$ref": "#/$defs/digest" }
      }
    },
    "resolvedCapability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "provider"],
      "properties": {
        "id": { "$ref": "#/$defs/namespacedId" },
        "version": { "$ref": "#/$defs/capabilityVersion" },
        "provider": { "$ref": "#/$defs/lockedPackage" },
        "change_history": {
          "type": "array",
          "items": { "$ref": "#/$defs/capabilityRevisionChange" }
        },
        "conformance_suite": { "$ref": "#/$defs/relativePath" }
      }
    },
    "requirementBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "consumer",
        "capability",
        "tested_against",
        "providers",
        "issues",
        "status"
      ],
      "properties": {
        "consumer": { "$ref": "#/$defs/namespacedId" },
        "capability": { "$ref": "#/$defs/namespacedId" },
        "tested_against": { "$ref": "#/$defs/capabilityVersion" },
        "providers": {
          "type": "array",
          "items": { "$ref": "#/$defs/providerCandidate" }
        },
        "issues": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "enum": [
              "no-declared-provider",
              "multiple-declared-providers",
              "self-declared-provider",
              "revision-difference"
            ]
          }
        },
        "status": { "enum": ["declared-aligned", "review"] }
      }
    },
    "providerCandidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider",
        "provided_version",
        "revision_status",
        "revision_direction",
        "revision_difference",
        "review_severity",
        "change_evidence",
        "declared_changes"
      ],
      "properties": {
        "provider": { "$ref": "#/$defs/lockedPackage" },
        "provided_version": { "$ref": "#/$defs/capabilityVersion" },
        "revision_status": { "enum": ["tested-revision", "different-revision"] },
        "revision_direction": { "enum": ["exact", "provider-newer", "provider-older"] },
        "revision_difference": { "enum": ["none", "patch", "minor", "major"] },
        "review_severity": { "enum": ["none", "low", "medium", "high"] },
        "change_evidence": { "enum": ["not-needed", "complete", "partial", "unavailable"] },
        "declared_changes": {
          "type": "array",
          "items": { "$ref": "#/$defs/capabilityRevisionChange" }
        }
      }
    },
    "compositionReview": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "severity", "packages"],
      "properties": {
        "code": {
          "enum": [
            "no-declared-provider",
            "multiple-declared-providers",
            "self-declared-provider",
            "revision-difference",
            "declared-package-conflict",
            "declared-capability-conflict",
            "declared-requirement-cycle"
          ]
        },
        "severity": { "enum": ["low", "medium", "high"] },
        "packages": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/namespacedId" }
        },
        "capability": { "$ref": "#/$defs/namespacedId" },
        "revision": { "$ref": "#/$defs/revisionReview" },
        "reason": { "type": "string", "minLength": 1 }
      },
      "allOf": [
        {
          "if": { "properties": { "code": { "const": "revision-difference" } }, "required": ["code"] },
          "then": { "required": ["revision"] },
          "else": { "not": { "required": ["revision"] } }
        }
      ]
    },
    "revisionReview": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tested_against",
        "provided_version",
        "direction",
        "difference",
        "change_evidence",
        "declared_changes"
      ],
      "properties": {
        "tested_against": { "$ref": "#/$defs/capabilityVersion" },
        "provided_version": { "$ref": "#/$defs/capabilityVersion" },
        "direction": { "enum": ["provider-newer", "provider-older"] },
        "difference": { "enum": ["patch", "minor", "major"] },
        "change_evidence": { "enum": ["complete", "partial", "unavailable"] },
        "declared_changes": {
          "type": "array",
          "items": { "$ref": "#/$defs/capabilityRevisionChange" }
        }
      }
    },
    "capabilityChange": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "summary"],
      "properties": {
        "id": { "$ref": "#/$defs/localId" },
        "type": { "enum": ["breaking", "additive", "clarifying"] },
        "summary": { "type": "string", "minLength": 1, "maxLength": 500 },
        "contract_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/localId" }
        }
      }
    },
    "capabilityRevisionChange": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "to", "changes"],
      "properties": {
        "from": { "$ref": "#/$defs/capabilityVersion" },
        "to": { "$ref": "#/$defs/capabilityVersion" },
        "changes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/capabilityChange" }
        }
      }
    },
    "localId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*(?:/[A-Za-z0-9][A-Za-z0-9._-]*)*$"
    },
    "namespacedId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:\\.[a-z0-9][a-z0-9-]*){2,}$"
    },
    "semver": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
    },
    "capabilityVersion": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$"
    }
  }
}
