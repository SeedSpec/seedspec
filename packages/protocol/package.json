{
  "name": "@seedspec/protocol",
  "version": "0.2.0",
  "description": "Schemas and metadata for portable, agent-ready SeedSpec packages",
  "keywords": [
    "seedspec",
    "protocol",
    "json-schema",
    "agents",
    "specifications",
    "portable"
  ],
  "type": "module",
  "exports": {
    ".": "./src/index.js",
    "./conformance-bundle.json": "./conformance-bundle.json",
    "./protocol-release.json": "./protocol-release.json",
    "./documents/*": "./documents/*",
    "./schemas/*": "./schemas/*"
  },
  "files": [
    "protocol-release.json",
    "conformance-bundle.json",
    "documents",
    "schemas",
    "src",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SeedSpec/seedspec.git",
    "directory": "packages/protocol"
  },
  "homepage": "https://seedspec.dev",
  "bugs": {
    "url": "https://github.com/SeedSpec/seedspec/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "author": "SeedSpec contributors",
  "license": "Apache-2.0"
}
